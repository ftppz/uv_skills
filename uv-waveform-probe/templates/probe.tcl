# =============================================================================
# probe.tcl 模板 - 改 <...> 部分即可
# 在 fe 阶段被 frontend.tcl/fe_run.tcl 自动 source, 注册探针和触发组
# 顶层模块名不一定是 top, 看设计的真实 module 名
# =============================================================================

# ---- 1. 探针：要观察的信号 ----
# -clock: 采样时钟全路径, 必须可见、非黑盒内部时钟
# -add:   信号全路径 <顶层模块>.<实例>.<信号>
probe_net -clock { <顶层模块>.<实例>.<时钟> } -add { \
    <顶层模块>.<实例>.<信号1> \
    <顶层模块>.<实例>.<信号2> \
}

# ---- 2. 触发组：在哪个信号触发(条件值在 uhd_setting.ini 里写) ----
# -group: 触发组名, 必须和 uhd_setting.ini / hw_run.tcl 一致
# -probe: 可选, 加上表示信号来自已注册的 probe_net
trigger_net -add -group <触发组名> \
    -clock <顶层模块>.<实例>.<时钟> \
    -signal { \
    <顶层模块>.<实例>.<触发信号> \
}
